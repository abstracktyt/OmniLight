<!-- ============================================================
     OmniLight by Abstrackt
     Файл: Info.plist — фрагмент для добавления в ios/Runner/Info.plist
     
     ВАЖНО: Эти ключи ОБЯЗАТЕЛЬНЫ для работы BLE на iOS.
     Без них приложение не получит разрешение на Bluetooth,
     и flutter_blue_plus не сможет сканировать устройства.
     
     App Store ОТКЛОНИТ сборку без NSBluetoothAlwaysUsageDescription.
     
     Вставьте следующие строки внутрь тега <dict> в Info.plist:
     ============================================================ -->

<!-- ─────────────────────────────────────────────────── -->
<!-- Разрешение Bluetooth (iOS 13+) — ОБЯЗАТЕЛЬНО       -->
<!-- ─────────────────────────────────────────────────── -->
<key>NSBluetoothAlwaysUsageDescription</key>
<string>OmniLight использует Bluetooth для поиска и управления LED-контроллером. Без этого разрешения приложение не может работать.</string>

<!-- ─────────────────────────────────────────────────── -->
<!-- Разрешение Bluetooth (iOS 12 и старше) — для       -->
<!-- совместимости со старыми устройствами              -->
<!-- ─────────────────────────────────────────────────── -->
<key>NSBluetoothPeripheralUsageDescription</key>
<string>OmniLight использует Bluetooth для управления LED-лентой.</string>

<!-- ─────────────────────────────────────────────────── -->
<!-- Опционально: фоновые режимы BLE                    -->
<!-- Раскомментируйте, если нужна работа в фоне         -->
<!-- ─────────────────────────────────────────────────── -->
