@echo off
:: ============================================================
:: OmniLight by Abstrackt
:: Файл: deploy.bat
:: Назначение: Автоматизация деплоя — одним кликом подготавливает
::             изменения, делает коммит с временной меткой и
::             пушит в ветку main, запуская GitHub Actions CI.
::
:: Использование:
::   Дважды кликните deploy.bat или запустите из командной строки:
::   > deploy.bat
::   > deploy.bat "Мой кастомный комментарий"
:: ============================================================

setlocal enabledelayedexpansion

:: Получаем текущую дату и время для сообщения коммита
for /f "tokens=1-3 delims=/" %%a in ('date /t') do (
    set DATE_DAY=%%a
    set DATE_MON=%%b
    set DATE_YR=%%c
)
for /f "tokens=1-2 delims=: " %%a in ('time /t') do (
    set TIME_HR=%%a
    set TIME_MIN=%%b
)

:: Формируем сообщение коммита
if "%~1"=="" (
    :: Автоматическое сообщение с временной меткой
    set COMMIT_MSG=Auto-deploy: Update OmniLight by Abstrackt [%DATE_DAY%/%DATE_MON%/%DATE_YR% %TIME_HR%:%TIME_MIN%]
) else (
    :: Кастомное сообщение из первого аргумента
    set COMMIT_MSG=%~1
)

echo.
echo ============================================================
echo   OmniLight by Abstrackt — Deploy Script
echo ============================================================
echo.

:: ────────────────────────────────────────────────────────
:: Шаг 1: Убедиться, что мы в корне Git-репозитория
:: ────────────────────────────────────────────────────────
git status >nul 2>&1
if errorlevel 1 (
    echo [ОШИБКА] Текущая папка не является Git-репозиторием.
    echo          Убедитесь, что вы запускаете deploy.bat из корня проекта.
    pause
    exit /b 1
)
echo [OK] Git-репозиторий найден.

:: ────────────────────────────────────────────────────────
:: Шаг 2: Добавляем все изменения в индекс
:: ────────────────────────────────────────────────────────
echo.
echo [1/3] Добавляем изменения: git add .
git add .
if errorlevel 1 (
    echo [ОШИБКА] Не удалось выполнить git add.
    pause
    exit /b 1
)
echo [OK] Все изменения добавлены.

:: ────────────────────────────────────────────────────────
:: Шаг 3: Проверяем, есть ли что коммитить
:: ────────────────────────────────────────────────────────
git diff --cached --quiet
if not errorlevel 1 (
    echo.
    echo [INFO] Нет изменений для коммита. Пуш не требуется.
    echo        Рабочее дерево чистое.
    pause
    exit /b 0
)

:: ────────────────────────────────────────────────────────
:: Шаг 4: Создаём коммит
:: ────────────────────────────────────────────────────────
echo.
echo [2/3] Создаём коммит: git commit
echo       Сообщение: "!COMMIT_MSG!"
git commit -m "!COMMIT_MSG!"
if errorlevel 1 (
    echo [ОШИБКА] Не удалось создать коммит.
    pause
    exit /b 1
)
echo [OK] Коммит создан.

:: ────────────────────────────────────────────────────────
:: Шаг 5: Пушим в ветку main (запускает GitHub Actions)
:: ────────────────────────────────────────────────────────
echo.
echo [3/3] Отправляем на GitHub: git push origin main
git push origin main
if errorlevel 1 (
    echo [ОШИБКА] Push завершился ошибкой.
    echo          Проверьте доступ к репозиторию и наличие upstream.
    echo          Используйте: git remote -v
    pause
    exit /b 1
)

echo.
echo ============================================================
echo   [УСПЕХ] OmniLight успешно задеплоен!
echo   GitHub Actions CI запущен автоматически.
echo   Проверьте статус на: https://github.com/[ваш-логин]/OmniLight/actions
echo ============================================================
echo.
pause
endlocal
