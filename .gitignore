# OmniLight by Abstrackt — .gitignore

# ── Flutter/Dart стандарт ──
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
pubspec.lock

# ── iOS/Xcode ──
ios/Pods/
ios/.symlinks/
ios/Flutter/ephemeral/
ios/Runner.xcworkspace/xcuserdata/
*.ipa
*.dSYM.zip
*.dSYM
DerivedData/
*.xccheckout
*.moved-aside
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3

# ── Android ──
**/android/local.properties
**/android/.gradle
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/gradle/
**/android/key.properties

# ── IDE ──
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Секреты (никогда не коммитьте!) ──
*.p12
*.p8
*.mobileprovision
secrets.json
.env
.env.local
GoogleService-Info.plist

# ── Логи ──
*.log
crash.log
